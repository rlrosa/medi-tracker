generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id          String       @id @default(cuid())
  name        String
  type        String       @default("SOLO")
  createdAt   DateTime     @default(now())
  invitations Invitation[]
  patients    Patient[]
  users       User[]
}

model User {
  id           String              @id @default(cuid())
  name         String?
  username     String?             @unique
  passwordHash String
  role         String              @default("USER")
  createdAt    DateTime            @default(now())
  accountId    String?
  email        String?             @unique
  logs         AdministrationLog[]
  patients     Patient[]
  account      Account?            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  defaultMovePreference String    @default("ASK") // "ASK" | "SINGLE" | "OFFSET"
}

model MedicationEventHistory {
  id           String   @id @default(cuid())
  userId       String
  actionType   String   // MOVE, DELETE, ADMINISTER
  description  String?
  undoData     String   // JSON string containing inverse action parameters
  timestamp    DateTime @default(now())
}

model Invitation {
  id         String    @id @default(cuid())
  email      String
  role       String    @default("CAREGIVER")
  token      String    @unique
  accountId  String?
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())
  account    Account?  @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Patient {
  id             String       @id @default(cuid())
  name           String
  selfMedication Boolean      @default(false)
  accountId      String?
  userId         String?
  createdAt      DateTime     @default(now())
  medications    Medication[]
  account        Account?     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id])
}

model Medication {
  id        String               @id @default(cuid())
  name      String
  alias     String?
  imageUrl  String?
  createdAt DateTime             @default(now())
  patientId String?
  patient   Patient?             @relation(fields: [patientId], references: [id], onDelete: Cascade)

  schedules MedicationSchedule[]
  logs      AdministrationLog[]
  events    MedicationEvent[]
}

model MedicationSchedule {
  id            String              @id @default(cuid())
  medicationId  String
  medication    Medication          @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  name          String?             // e.g. "Morning Dose"
  intervalHours Int?
  daysOfWeek    String?
  startDate     DateTime?
  endDate       DateTime?
  marginMinutes Int                 @default(30)
  color         String?
  icon          String?
  createdAt     DateTime            @default(now())
  logs          AdministrationLog[]
  events        MedicationEvent[]
}

model MedicationEvent {
  id           String             @id @default(cuid())
  scheduleId   String
  schedule     MedicationSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  medicationId String
  medication   Medication          @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  
  time         DateTime           // Current planned time
  originalTime DateTime?          // Anchor time (optional if not shifted)
  status       String             @default("PENDING") // PENDING, COMPLETED, SKIPPED, MISSED
  
  log          AdministrationLog? @relation("EventToLog")
  createdAt    DateTime           @default(now())
}

model AdministrationLog {
  id                   String     @id @default(cuid())
  medicationId         String
  scheduleId           String?
  status               String     @default("ADMINISTERED") // "ADMINISTERED" | "SKIPPED"
  administeredAt       DateTime
  administeredByUserId String?
  notes                String?
  createdAt            DateTime   @default(now())
  scheduledAt          DateTime?
  administeredByUser   User?      @relation(fields: [administeredByUserId], references: [id])
  medication           Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  schedule             MedicationSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  
  eventId              String?             @unique
  event                MedicationEvent?    @relation("EventToLog", fields: [eventId], references: [id])
}

model Setting {
  key   String @id
  value String
}

model MedicationTemplate {
  id            String  @id @default(cuid())
  name          String
  intervalHours Int?
  marginMinutes Int     @default(30)
  daysOfWeek    String?
  color         String?
  icon          String?
}
