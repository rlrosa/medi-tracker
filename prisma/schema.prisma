generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Account {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("SOLO") // 'SOLO' or 'COORDINATOR'
  users     User[]
  patients  Patient[]
  invitations Invitation[]
  createdAt DateTime @default(now())
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  role          String    @default("USER") // 'ADMIN' or 'USER'
  
  accountId     String
  account       Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  logs          AdministrationLog[]
  patients      Patient[]
  createdAt     DateTime  @default(now())
}

model Invitation {
  id             String   @id @default(cuid())
  email          String
  role           String   @default("CAREGIVER")
  token          String   @unique
  accountId      String
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expiresAt      DateTime
  acceptedAt     DateTime?
  
  createdAt      DateTime @default(now())
}

model Patient {
  id             String    @id @default(cuid())
  name           String
  selfMedication Boolean   @default(false)
  
  accountId      String
  account        Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  userId         String?
  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  medications    Medication[]
  createdAt      DateTime  @default(now())
}

model Medication {
  id            String    @id @default(cuid())
  name          String
  alias         String?
  imageUrl      String?
  color         String?   // Hex color
  icon          String?   // Lucide icon name
  
  // Schedule
  intervalHours Int?
  marginMinutes Int      @default(30)
  daysOfWeek    String?   // e.g. "1,3,5" for Mon/Wed/Fri
  startDate     DateTime?
  endDate       DateTime?

  patientId     String
  patient       Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)

  logs          AdministrationLog[]
  createdAt     DateTime  @default(now())
}

model AdministrationLog {
  id                   String      @id @default(cuid())
  medicationId         String
  medication           Medication  @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  
  administeredAt       DateTime
  scheduledAt          DateTime?
  
  administeredByUserId String?
  administeredByUser   User?       @relation(fields: [administeredByUserId], references: [id], onDelete: SetNull)
  
  notes                String?
  createdAt            DateTime    @default(now())
}

model Setting {
  key   String @id
  value String
}

model MedicationTemplate {
  id            String    @id @default(cuid())
  name          String
  intervalHours Int?
  marginMinutes Int      @default(30)
  daysOfWeek    String?
  color         String?
  icon          String?
}
