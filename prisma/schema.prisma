generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id          String       @id @default(cuid())
  name        String
  type        String       @default("SOLO")
  createdAt   DateTime     @default(now())
  invitations Invitation[]
  patients    Patient[]
  users       User[]
}

model User {
  id                    String              @id @default(cuid())
  name                  String?
  username              String?             @unique
  passwordHash          String
  role                  String              @default("USER")
  createdAt             DateTime            @default(now())
  accountId             String?
  email                 String?             @unique
  defaultMovePreference String              @default("ASK")
  logs                  AdministrationLog[]
  patients              Patient[]
  account               Account?            @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model MedicationEventHistory {
  id          String   @id @default(cuid())
  userId      String
  actionType  String
  description String?
  undoData    String
  redoData    String?
  isUndone    Boolean  @default(false)
  timestamp   DateTime @default(now())

  @@index([userId, timestamp])
}

model Invitation {
  id         String    @id @default(cuid())
  email      String
  role       String    @default("CAREGIVER")
  token      String    @unique
  accountId  String?
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())
  account    Account?  @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Patient {
  id             String       @id @default(cuid())
  name           String
  selfMedication Boolean      @default(false)
  accountId      String?
  userId         String?
  createdAt      DateTime     @default(now())
  medications    Medication[]
  user           User?        @relation(fields: [userId], references: [id])
  account        Account?     @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Medication {
  id                 String                   @id @default(cuid())
  name               String
  alias              String?
  imageUrl           String?
  createdAt          DateTime                 @default(now())
  patientId          String?
  maxIntervalMinutes Int?
  minIntervalMinutes Int?
  logs               AdministrationLog[]
  patient            Patient?                 @relation(fields: [patientId], references: [id], onDelete: Cascade)
  events             MedicationEvent[]
  relationshipsAsB   MedicationRelationship[] @relation("MedicationB")
  relationshipsAsA   MedicationRelationship[] @relation("MedicationA")
  schedules          MedicationSchedule[]
}

model MedicationSchedule {
  id            String              @id @default(cuid())
  medicationId  String
  name          String?
  intervalHours Int?
  daysOfWeek    String?
  startDate     DateTime?
  endDate       DateTime?
  marginMinutes Int                 @default(30)
  color         String?
  icon          String?
  createdAt     DateTime            @default(now())
  logs          AdministrationLog[]
  events        MedicationEvent[]
  medication    Medication          @relation(fields: [medicationId], references: [id], onDelete: Cascade)
}

model MedicationEvent {
  id           String             @id @default(cuid())
  scheduleId   String
  medicationId String
  time         DateTime
  originalTime DateTime?
  status       String             @default("PENDING")
  warningType  String?
  isOverride   Boolean            @default(false)
  createdAt    DateTime           @default(now())
  log          AdministrationLog? @relation("EventToLog")
  schedule     MedicationSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  medication   Medication         @relation(fields: [medicationId], references: [id], onDelete: Cascade)
}

model AdministrationLog {
  id                   String              @id @default(cuid())
  medicationId         String
  scheduleId           String?
  status               String              @default("ADMINISTERED")
  administeredAt       DateTime
  administeredByUserId String?
  notes                String?
  warningType          String?
  isOverride           Boolean             @default(false)
  createdAt            DateTime            @default(now())
  scheduledAt          DateTime?
  eventId              String?             @unique
  administeredByUser   User?               @relation(fields: [administeredByUserId], references: [id])
  medication           Medication          @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  schedule             MedicationSchedule? @relation(fields: [scheduleId], references: [id])
  event                MedicationEvent?    @relation("EventToLog", fields: [eventId], references: [id])
}

model MedicationRelationship {
  id            String     @id @default(cuid())
  medicationAId String
  medicationBId String
  type          String
  valueMinutes  Int?
  createdAt     DateTime   @default(now())
  medicationB   Medication @relation("MedicationB", fields: [medicationBId], references: [id])
  medicationA   Medication @relation("MedicationA", fields: [medicationAId], references: [id])
}

model Setting {
  key   String @id
  value String
}

model MedicationTemplate {
  id            String  @id @default(cuid())
  name          String
  intervalHours Int?
  marginMinutes Int     @default(30)
  daysOfWeek    String?
  color         String?
  icon          String?
}
