generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String    @unique
  passwordHash  String
  role          String    @default("USER") // 'ADMIN' or 'USER'
  logs          AdministrationLog[]
  createdAt     DateTime  @default(now())
}

model Medication {
  id            String    @id @default(cuid())
  name          String
  alias         String?
  imageUrl      String?
  
  // Schedule
  intervalHours Int?
  marginMinutes Int      @default(30)
  daysOfWeek    String?   // e.g. "1,3,5" for Mon/Wed/Fri
  startDate     DateTime?
  endDate       DateTime?

  logs          AdministrationLog[]
  createdAt     DateTime  @default(now())
}

model AdministrationLog {
  id                   String      @id @default(cuid())
  medicationId         String
  medication           Medication  @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  
  administeredAt       DateTime
  scheduledAt          DateTime?
  
  administeredByUserId String?
  administeredByUser   User?       @relation(fields: [administeredByUserId], references: [id], onDelete: SetNull)
  
  notes                String?
  createdAt            DateTime    @default(now())
}

model Setting {
  key   String @id
  value String
}
